# HashGoblin Discord bot config
# IMPORTANT: never share your DISCORD_TOKEN and never commit a real .env file.

DISCORD_TOKEN=put-your-reset-bot-token-here
DISCORD_CLIENT_ID=your-discord-client-id-here
DISCORD_GUILD_ID=your-discord-server-id-here

# Database path. Keep this persistent on the VPS.
HASHGOBLIN_DB=./data/hashgoblin.sqlite

# Economy defaults
HASHGOBLIN_DEFAULT_CURRENCY=Glory
NODE_ENV=production

# Optional game polish. Leave off until you want the slots reveal animation.
HASHGOBLIN_ANIMATED_SLOTS=false
HASHGOBLIN_SLOT_ANIMATION_DELAY_MS=650
