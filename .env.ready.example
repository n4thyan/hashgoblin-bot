# Copy this file to .env on the VPS, then paste your NEW RESET bot token.
# Do not use the token you pasted into chat. Reset it in Discord Developer Portal first.

DISCORD_TOKEN=PASTE_NEW_RESET_TOKEN_HERE
DISCORD_CLIENT_ID=your-discord-client-id-here
DISCORD_GUILD_ID=your-discord-server-id-here
HASHGOBLIN_DB=./data/hashgoblin.sqlite
HASHGOBLIN_DEFAULT_CURRENCY=Glory
NODE_ENV=production
